{
  "version": 1,
  "defaults": {
    "include": ["*.md", "**/*.md"],
    "exclude": [
      "**/*:Zone.Identifier",
      "**/catalog.md",
      "**/README.md"
    ],
    "section_from": ["menu_path[0]", "rel_path[0]"],
    "doc_type_rules": [
      {"match": "path_contains", "any": ["接口文档", "/api/", "参考"], "type": "api"},
      {"match": "path_contains", "any": ["FAQ", "常见问题"], "type": "faq"},
      {"match": "path_contains", "any": ["最佳实践"], "type": "practice"},
      {"match": "path_contains", "any": ["指南", "guide"], "type": "guide"}
    ],
    "nav_rules": {
      "filenames": ["catalog.md", "README.md", "index.md"],
      "min_body_chars": 300
    },
    "chunk": {
      "target_chars": 1200,
      "max_chars": 1500,
      "overlap_chars": 150
    }
  },
  "docsets": [
    {
      "id": "harmonyos",
      "name": "HarmonyOS",
      "root": "docs/HarmonyOS",
      "chunk": {
        "target_chars": 2200,
        "max_chars": 2800,
        "overlap_chars": 120
      }
    },
    {
      "id": "pinduoduo",
      "name": "拼多多开放平台",
      "root": "docs/拼多多"
    },
    {
      "id": "sing-box",
      "name": "sing-box",
      "root": "docs/sing-box"
    },
    {
      "id": "chatbox",
      "name": "Chatbox",
      "root": "docs/chatbox",
      "chunk": {
        "target_chars": 1800,
        "max_chars": 2400,
        "overlap_chars": 120
      }
    },
    {
      "id": "ai-sdk",
      "name": "AI SDK v6",
      "root": "docs/AI-SDK",
      "description": "Vercel AI SDK v6 官方文档快照，包含指南、Core/UI/RSC、Provider 与 Cookbook 示例。",
      "topics": ["Vercel AI SDK", "AI SDK v6", "generateText", "streamText", "useChat", "providers", "tools", "agents"],
      "recommended_queries": ["generateText streamText tools", "useChat UIMessage transport", "provider openai anthropic google", "migration guide 6.0", "MCP tools runtime context"],
      "source_sets": ["vercel/ai@ai@6.0.191 content/docs", "vercel/ai@ai@6.0.191 content/providers", "vercel/ai@ai@6.0.191 content/cookbook"],
      "chunk": {
        "target_chars": 1800,
        "max_chars": 2400,
        "overlap_chars": 120
      }
    }
  ]
}
